APP_NAME="Drone Inzet Systeem"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://dis.example.nl
APP_TIMEZONE=UTC

DIS_INSTALL_PATH=/opt/dis
DIS_MAINTENANCE_ALLOWED_IPS=

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=dis
DB_USERNAME=dis_app
DB_PASSWORD=change-this-database-password

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_SECURE_COOKIE=false
SESSION_SAME_SITE=strict

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=dis
REVERB_APP_KEY=change-this-reverb-key
REVERB_APP_SECRET=change-this-reverb-secret
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=http
