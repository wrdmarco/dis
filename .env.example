APP_NAME="Drone Inzet Systeem"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://dis.example.nl
APP_TIMEZONE=Europe/Amsterdam
TRUSTED_PROXIES=127.0.0.1,::1
CORS_ALLOWED_ORIGINS=https://dis.example.nl

# Required for a public RFC 9116 security.txt response. Use a monitored mailto: or https: URI.
SECURITY_CONTACT=
CSP_AERET_FRAME_ORIGINS=

DIS_INSTALL_PATH=/opt/dis
DIS_DATA_PATH=/opt/dis-data

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=dis
DB_USERNAME=dis_app
DB_PASSWORD=change-this-database-password

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
QUEUE_CONNECTION=redis
PUSH_QUEUE_RETRY_AFTER=240
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ABSOLUTE_LIFETIME=720
SESSION_COOKIE=__Host-dis_session
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_TRUSTED_ORIGINS=https://dis.example.nl
SANCTUM_STATEFUL_DOMAINS=dis.example.nl

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=dis
REVERB_APP_KEY=change-this-reverb-key
REVERB_APP_SECRET=change-this-reverb-secret
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=http

AERET_DRONE_MAP_URL=https://dronepreflight.nl/
AERET_API_URL=

# Exact coordinates go only to the trusted PDOK/GISCO classification endpoints.
# Province/country is stored per incident; wallboards expose aggregate counts only.
INCIDENT_LOCATION_ENRICHMENT_ENABLED=true
INCIDENT_PROVINCE_WFS_URL=https://service.pdok.nl/kadaster/brk-bestuurlijke-gebieden/wfs/v1_0
INCIDENT_COUNTRY_GISCO_URL=https://gisco-services.ec.europa.eu/id/country
INCIDENT_LOCATION_CONNECT_TIMEOUT_SECONDS=2
INCIDENT_LOCATION_TIMEOUT_SECONDS=5
# Two lanes are mandatory (newest never-attempted + oldest due); valid range 2-3.
INCIDENT_LOCATION_BACKFILL_BATCH=3

# Optional dedicated KNMI EDR key (not an Open Data API key) for the nearest measured cloud base.
KNMI_EDR_API_KEY=
# Dedicated KNMI Open Data key for local HARMONIE, radar and precipitation datasets.
KNMI_OPEN_DATA_API_KEY=
# Completed per-dataset refresh traces are retained for bounded operational diagnostics.
WEATHER_DATASET_OPERATION_RETENTION_DAYS=14
WALLBOARD_UAV_CLOUD_BASE_STALE_SECONDS=1800
WALLBOARD_UAV_CLOUD_BASE_MAX_DISTANCE_KM=30

# Larger MP4 sources are verified and queued for browser-safe H.264/AAC conversion at max. 1080p.
WALLBOARD_MEDIA_MAX_VIDEO_UPLOAD_KB=524288

# Self-hosted Dutch speech. Generated audio/models/runtimes are reproducible
# data below /opt/dis-data/tts; encrypted consented voice originals remain in
# the normal Laravel storage backup. A fresh setup generates the HMAC key.
SPEECH_ENGINE_SOCKET=/run/dis-tts/engine.sock
SPEECH_ENGINE_CONNECT_TIMEOUT_SECONDS=1
SPEECH_ENGINE_SYNTHESIS_TIMEOUT_SECONDS=14400
SPEECH_ENGINE_INSTALL_TIMEOUT_SECONDS=14400
SPEECH_QUEUE_RETRY_AFTER=68400
SPEECH_DATA_ROOT=/opt/dis-data/tts
SPEECH_CACHE_ROOT=/opt/dis-data/tts/cache
SPEECH_STAGING_ROOT=/opt/dis-data/tts/staging
SPEECH_CACHE_HMAC_KEY=
SPEECH_CACHE_QUOTA_BYTES=5368709120
SPEECH_SEGMENT_RETENTION_DAYS=30
SPEECH_COMPOSITE_RETENTION_DAYS=7
SPEECH_PREVIEW_RETENTION_HOURS=24

# Road-based ETA. Point this only at an OSRM instance controlled by the operator.
ROUTING_ENABLED=false
ROUTING_PROVIDER=osrm
OSRM_BASE_URL=
OSRM_ALLOWED_HOSTS=127.0.0.1,localhost,::1
OSRM_PROFILE=driving
OSRM_CONNECT_TIMEOUT_SECONDS=1
OSRM_TIMEOUT_SECONDS=3
OSRM_BATCH_SIZE=50
OSRM_GEOMETRY_MAX_ROUTES=25
OSRM_GEOMETRY_CONCURRENCY=10
ROUTING_CACHE_TTL_SECONDS=900
ROUTING_FAILURE_CACHE_TTL_SECONDS=15
ROUTING_FALLBACK_SPEED_KMH=60

BACKUP_DISK_PATH=/opt/dis-data/backup
BACKUP_ENCRYPTION_KEY_FILE=/opt/dis-data/secrets/backup-encryption.key
