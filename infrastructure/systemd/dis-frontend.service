[Unit]
Description=DIS Next.js frontend
After=network.target

[Service]
Type=simple
User=dis
Group=dis
WorkingDirectory=/opt/dis/webapp/frontend
Environment=NODE_ENV=production
ExecStart=/usr/bin/npm run start
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/opt/dis/webapp/frontend/.next /opt/dis/webapp/frontend/node_modules

[Install]
WantedBy=multi-user.target
