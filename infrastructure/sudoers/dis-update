Cmnd_Alias DIS_UPDATE = /usr/bin/bash /opt/dis/update.sh --skip-system, /bin/bash /opt/dis/update.sh --skip-system, /usr/bin/bash /opt/dis/scripts/update.sh --skip-system, /bin/bash /opt/dis/scripts/update.sh --skip-system, /usr/local/bin/update --skip-system, /usr/local/bin/update
Cmnd_Alias DIS_UPDATE_RUNNER = /usr/bin/systemd-run * /usr/local/bin/dis-update-runner, /bin/systemd-run * /usr/local/bin/dis-update-runner, /usr/bin/systemd-run * /usr/local/bin/dis-update-runner --skip-system, /bin/systemd-run * /usr/local/bin/dis-update-runner --skip-system
Cmnd_Alias DIS_REBOOT = /usr/bin/systemctl reboot, /bin/systemctl reboot

dis ALL=(root) NOPASSWD: DIS_UPDATE
%dis ALL=(root) NOPASSWD: DIS_UPDATE
dis ALL=(root) NOPASSWD: DIS_UPDATE_RUNNER
%dis ALL=(root) NOPASSWD: DIS_UPDATE_RUNNER
dis ALL=(root) NOPASSWD: DIS_REBOOT
%dis ALL=(root) NOPASSWD: DIS_REBOOT
