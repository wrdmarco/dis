APP_NAME="Drone Inzet Systeem"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://dis.example.nl
APP_TIMEZONE=Europe/Amsterdam
TRUSTED_PROXIES=127.0.0.1,::1
CORS_ALLOWED_ORIGINS=https://dis.example.nl

SECURITY_CONTACT=
CSP_AERET_FRAME_ORIGINS=

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=dis
DB_USERNAME=dis_app
DB_PASSWORD=change-this-database-password

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ABSOLUTE_LIFETIME=720
SESSION_COOKIE=__Host-dis_session
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_TRUSTED_ORIGINS=https://dis.example.nl
SANCTUM_STATEFUL_DOMAINS=dis.example.nl

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=dis
REVERB_APP_KEY=change-this-reverb-key
REVERB_APP_SECRET=change-this-reverb-secret
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
REVERB_SERVER_PATH=
REVERB_PULSE_INGEST_INTERVAL=15
REVERB_TELESCOPE_INGEST_INTERVAL=15
REVERB_APP_ACCEPT_CLIENT_EVENTS_FROM=members
REVERB_APP_RATE_LIMITING_ENABLED=false
REVERB_APP_RATE_LIMIT_MAX_ATTEMPTS=60
REVERB_APP_RATE_LIMIT_DECAY_SECONDS=60
REVERB_APP_RATE_LIMIT_TERMINATE=false

MAIL_MAILER=smtp
MAIL_FROM_ADDRESS=no-reply@dis.example.nl
MAIL_FROM_NAME="Drone Inzet Systeem"
MICROSOFT365_TENANT_ID=
MICROSOFT365_CLIENT_ID=
MICROSOFT365_CLIENT_SECRET=
MICROSOFT365_SENDER=

GEOCODING_ENABLED=true
GEOCODING_PROVIDER=nominatim
GEOCODING_NOMINATIM_URL=https://nominatim.openstreetmap.org/search
GEOCODING_USER_AGENT=
GEOCODING_COUNTRY_CODES=nl,be,de

# Exact coordinates go only to the trusted PDOK/GISCO classification endpoints.
# Province/country is stored per incident; wallboards expose aggregate counts only.
INCIDENT_LOCATION_ENRICHMENT_ENABLED=true
INCIDENT_PROVINCE_WFS_URL=https://service.pdok.nl/kadaster/brk-bestuurlijke-gebieden/wfs/v1_0
INCIDENT_COUNTRY_GISCO_URL=https://gisco-services.ec.europa.eu/id/country
INCIDENT_LOCATION_CONNECT_TIMEOUT_SECONDS=2
INCIDENT_LOCATION_TIMEOUT_SECONDS=5
# Two lanes are mandatory (newest never-attempted + oldest due); valid range 2-3.
INCIDENT_LOCATION_BACKFILL_BATCH=3

# Optional dedicated KNMI EDR key (not an Open Data API key) for the nearest measured cloud base.
KNMI_EDR_API_KEY=
# KNMI Open Data key for the HARMONIE archive plus the five-minute radar and
# seamless precipitation products. When omitted, existing installations
# temporarily fall back to KNMI_EDR_API_KEY.
KNMI_OPEN_DATA_API_KEY=
# In a multi-server deployment this exact path must be the same shared POSIX
# filesystem on every web/queue node and must support atomic rename.
KNMI_FORECAST_STORAGE_ROOT=/opt/dis-data/webapp/backend/storage/app/knmi-forecast
KNMI_FORECAST_MAX_ARCHIVE_BYTES=1181116006
KNMI_FORECAST_DOWNLOAD_TIMEOUT_SECONDS=1800
KNMI_FORECAST_MAXIMUM_MODEL_AGE_SECONDS=21600
KNMI_FORECAST_MAXIMUM_VALID_OFFSET_SECONDS=3600
KNMI_FORECAST_INTEGRITY_CACHE_SECONDS=900
KNMI_FORECAST_POINT_CACHE_SECONDS=21600
KNMI_FORECAST_QUERY_TIMEOUT_SECONDS=10
KNMI_QUEUE_RETRY_AFTER=7500
# The five-minute radar and seamless products are kept as a separate atomic
# local snapshot below the large HARMONIE archive. Keep this on shared storage
# for multi-server installations.
KNMI_PRECIPITATION_STORAGE_ROOT=/opt/dis-data/webapp/backend/storage/app/knmi-forecast/precipitation-outlook
KNMI_PRECIPITATION_DOWNLOAD_TIMEOUT_SECONDS=180
KNMI_PRECIPITATION_MAXIMUM_REFERENCE_AGE_SECONDS=1200
KNMI_PRECIPITATION_QUERY_TIMEOUT_SECONDS=10
KNMI_REALTIME_QUEUE_RETRY_AFTER=900
WALLBOARD_UAV_CLOUD_BASE_STALE_SECONDS=1800
WALLBOARD_UAV_CLOUD_BASE_MAX_DISTANCE_KM=30

# Larger MP4 sources are verified and queued for browser-safe H.264/AAC conversion at max. 1080p.
WALLBOARD_MEDIA_MAX_VIDEO_UPLOAD_KB=524288

# Road-based ETA. Point this only at an OSRM instance controlled by the operator.
ROUTING_ENABLED=false
ROUTING_PROVIDER=osrm
OSRM_BASE_URL=
OSRM_ALLOWED_HOSTS=127.0.0.1,localhost,::1
OSRM_PROFILE=driving
OSRM_CONNECT_TIMEOUT_SECONDS=1
OSRM_TIMEOUT_SECONDS=3
OSRM_BATCH_SIZE=50
OSRM_GEOMETRY_MAX_ROUTES=25
OSRM_GEOMETRY_CONCURRENCY=10
ROUTING_CACHE_TTL_SECONDS=900
ROUTING_FAILURE_CACHE_TTL_SECONDS=15
ROUTING_FALLBACK_SPEED_KMH=60
