APP_NAME="Drone Inzet Systeem"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://dis.example.nl

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=dis
DB_USERNAME=dis_app
DB_PASSWORD=change-this-database-password

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=dis
REVERB_APP_KEY=change-this-reverb-key
REVERB_APP_SECRET=change-this-reverb-secret
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=http
