APP_NAME="Drone Inzet Systeem"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://dis.example.nl
APP_TIMEZONE=Europe/Amsterdam
TRUSTED_PROXIES=127.0.0.1,::1
CORS_ALLOWED_ORIGINS=https://dis.example.nl

SECURITY_CONTACT=
CSP_AERET_FRAME_ORIGINS=

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=dis
DB_USERNAME=dis_app
DB_PASSWORD=change-this-database-password

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ABSOLUTE_LIFETIME=720
SESSION_COOKIE=__Host-dis_session
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_TRUSTED_ORIGINS=https://dis.example.nl
SANCTUM_STATEFUL_DOMAINS=dis.example.nl

BROADCAST_CONNECTION=reverb
REVERB_APP_ID=dis
REVERB_APP_KEY=change-this-reverb-key
REVERB_APP_SECRET=change-this-reverb-secret
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
REVERB_SERVER_PATH=
REVERB_PULSE_INGEST_INTERVAL=15
REVERB_TELESCOPE_INGEST_INTERVAL=15
REVERB_APP_ACCEPT_CLIENT_EVENTS_FROM=members
REVERB_APP_RATE_LIMITING_ENABLED=false
REVERB_APP_RATE_LIMIT_MAX_ATTEMPTS=60
REVERB_APP_RATE_LIMIT_DECAY_SECONDS=60
REVERB_APP_RATE_LIMIT_TERMINATE=false

MAIL_MAILER=smtp
MAIL_FROM_ADDRESS=no-reply@dis.example.nl
MAIL_FROM_NAME="Drone Inzet Systeem"
MICROSOFT365_TENANT_ID=
MICROSOFT365_CLIENT_ID=
MICROSOFT365_CLIENT_SECRET=
MICROSOFT365_SENDER=

GEOCODING_ENABLED=true
GEOCODING_PROVIDER=nominatim
GEOCODING_NOMINATIM_URL=https://nominatim.openstreetmap.org/search
GEOCODING_USER_AGENT=
GEOCODING_COUNTRY_CODES=nl,be,de

# Road-based ETA. Point this only at an OSRM instance controlled by the operator.
ROUTING_ENABLED=false
ROUTING_PROVIDER=osrm
OSRM_BASE_URL=
OSRM_ALLOWED_HOSTS=127.0.0.1,localhost,::1
OSRM_PROFILE=driving
OSRM_CONNECT_TIMEOUT_SECONDS=1
OSRM_TIMEOUT_SECONDS=3
OSRM_BATCH_SIZE=50
OSRM_GEOMETRY_MAX_ROUTES=25
OSRM_GEOMETRY_CONCURRENCY=10
ROUTING_CACHE_TTL_SECONDS=900
ROUTING_FAILURE_CACHE_TTL_SECONDS=15
ROUTING_FALLBACK_SPEED_KMH=60
